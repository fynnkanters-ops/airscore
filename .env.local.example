# ===================================================================
# AirScore – Umgebungsvariablen (alle OPTIONAL)
# ===================================================================
# Die App läuft komplett OHNE diese Variablen: die Berichte werden von der
# lokalen Engine (lib/analysis/localProvider.ts) im Browser erzeugt – kein
# API-Key, kein Server nötig. Straßensuche (Nominatim) & POIs (Overpass) sind
# kostenlose öffentliche APIs ohne Key.
#
# Die Variablen unten brauchst du nur, wenn du später ein eigenes Backend /
# Claude für die Texte nutzen willst.
# -------------------------------------------------------------------

# Provider umschalten: "local" (Default) oder "claude"
# NEXT_PUBLIC_ANALYSIS_MODE=claude

# Endpoint deines Backends (muss { ai: AIAnalysis } zurückgeben).
# Beispiel-Backend liegt in server-examples/analyze-route.ts.
# NEXT_PUBLIC_ANALYSIS_ENDPOINT=https://dein-backend.vercel.app/api/analyze

# GitHub-Pages-Unterpfad (= Repo-Name). Default: /airscore
# Nur ändern, wenn dein Repository anders heißt.
# NEXT_PUBLIC_BASE_PATH=/airscore

# Nur für das optionale Claude-Backend (server-examples/analyze-route.ts),
# NICHT im Browser/Frontend verwenden:
# ANTHROPIC_API_KEY=sk-ant-api03-...
